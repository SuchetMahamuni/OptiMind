# ─── OptiMind Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-min32chars

# JWT
JWT_SECRET_KEY=another-super-secret-jwt-key-min32chars

# Database  (SQLite path relative to project root)
DATABASE_URL=sqlite:///optimind.db
